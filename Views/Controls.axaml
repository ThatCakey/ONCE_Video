          Margin="2"
          Padding="1"
          Background="#2e2b2b">
          <TextBlock
            FontSize="16"
            Foreground="White"
            Text="Controll" />
        </Border>
        <Border
          Height="25"
          Margin="2"
          Padding="1"
          Background="#2e2b2b">
          <TextBlock
            FontSize="16"
            Foreground="White"
            Text="Controll" />
        </Border>
        <Border
