<Window
    x:Class="once.Views.TextInputDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Enter Text"
    Width="300"
    Height="150"
    WindowStartupLocation="CenterOwner">

    <Border Padding="10" Background="#1b1919">
        <StackPanel Margin="20" Spacing="10">
            <TextBlock Foreground="#aaa" Text="Enter new name:" />
            <TextBox
                x:Name="InputTextBox"
                Background="#2d2a2a"
                Foreground="#aaa" />
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">
                <Button
                    Width="80"
                    Click="OK_Click"
                    Content="OK" />
                <Button
                    Width="80"
                    Click="Cancel_Click"
                    Content="Cancel" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
