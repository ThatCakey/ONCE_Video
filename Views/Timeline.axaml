<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="once.Views.Timeline"
             xmlns:vm="using:once.ViewModels">
  
  <Grid ColumnDefinitions="1*" RowDefinitions="30,30,1*">

    <Border Grid.Column="0" Grid.Row="0" Background="#1b1919">
      <TextBlock Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#aaa" Text="Timeline Tools" />
    </Border>

    <Border Grid.Column="0" Grid.Row="1" Background="#2d2a2a">
      <TextBlock Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#aaa" Text="Timelines" />
    </Border>

    <Border Grid.Column="0" Grid.Row="2" Background="#1b1919">
      <TextBlock Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#aaa" Text="Timeline Content Area" />
    </Border>

  </Grid>


</UserControl>
