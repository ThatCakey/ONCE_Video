<UserControl
    x:Class="once.Views.MainPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:once.Views">


    <Grid ColumnDefinitions="2*,5,5*" RowDefinitions="4*,5,3*">
        <!--  Top-Left  -->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Background="#221e1e">
            <local:FileManager />
        </Border>

        <!--  Vertical Splitter (Top)  -->
        <GridSplitter
            Grid.Row="0"
            Grid.Column="1"
            Width="5"
            VerticalAlignment="Stretch"
            Background="#444" />

        <!--  Top-Right  -->
        <Border
            Grid.Row="0"
            Grid.Column="2"
            Background="#2a2727">
            <local:Viewport />
        </Border>

        <!--  Horizontal Splitter (Left)  -->
        <GridSplitter
            Grid.Row="1"
            Grid.Column="0"
            Height="5"
            HorizontalAlignment="Stretch"
            Background="#444" />

        <!--  Center Splitter  -->
        <GridSplitter
            Grid.Row="1"
            Grid.Column="1"
            Width="5"
            Height="5"
            Background="#555" />

        <!--  Horizontal Splitter (Right)  -->
        <GridSplitter
            Grid.Row="1"
            Grid.Column="2"
            Height="5"
            HorizontalAlignment="Stretch"
            Background="#444" />

        <!--  Bottom-Left  -->
        <Border
            Grid.Row="2"
            Grid.Column="0"
            Background="#221e1e">
            <local:Controls />
        </Border>

        <!--  Vertical Splitter (Bottom)  -->
        <GridSplitter
            Grid.Row="2"
            Grid.Column="1"
            Width="5"
            VerticalAlignment="Stretch"
            Background="#444" />

        <!--  Bottom-Right  -->
        <Border
            Grid.Row="2"
            Grid.Column="2"
            Background="#2a2727">
            <local:Timeline />
        </Border>
    </Grid>
</UserControl>
